{
  "name": "whatsapp-conduit",
  "version": "0.1.0",
  "description": "Passive, observe-only WhatsApp linked-device bridge: Baileys in, SQLite out.",
  "license": "MIT",
  "author": "Nicolai Schmid",
  "type": "module",
  "bin": {
    "whatsapp-conduit": "dist/cli.js"
  },
  "files": [
    "dist",
    "migrations",
    "systemd",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "baileys": "7.0.0-rc13",
    "better-sqlite3": "^12.11.1",
    "commander": "^15.0.0",
    "pino": "^10.3.1",
    "qrcode-terminal": "^0.12.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/qrcode-terminal": "^0.12.2",
    "eslint": "^9.39.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.4.0"
}
